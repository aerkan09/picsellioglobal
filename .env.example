# ===========================================
# PICSELLIO – Sunucu / Docker ortam değişkenleri
# Kopyalayın: cp .env.example .env  (sunucuda /opt/picsellioglobal)
# ===========================================

# --- Veritabanı (Docker Postgres) ---
POSTGRES_USER=picsellio
POSTGRES_PASSWORD=GÜÇLÜ_ŞİFRE_BURAYA
POSTGRES_DB=picsellio

# --- API / Auth ---
JWT_SECRET=uzun-rastgele-32-karakter-veya-fazla
JWT_EXPIRES_IN=7d

# --- Admin (ilk giriş – seed ile oluşturulur) ---
ADMIN_USERNAME=Admin
ADMIN_PASSWORD=güvenli_admin_şifresi

# --- Site adresleri (production) ---
FRONTEND_URL=https://picsellioglobal.com
NEXT_PUBLIC_API_URL=https://picsellioglobal.com
# Sunucuda API aynı domain altındaysa: https://picsellioglobal.com (Nginx /api → backend)

# --- Ödeme / Shopier ---
SHOPIER_API_KEY=
SHOPIER_API_SECRET=
SHOPIER_CALLBACK_URL=https://picsellioglobal.com/api/shopier/callback

# --- AI / Görsel ---
OPENAI_API_KEY=
PHOTOROOM_API_KEY=
STABILITY_API_KEY=
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
GOOGLE_VISION_API_KEY=

# --- SMTP (e-posta) ---
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=
